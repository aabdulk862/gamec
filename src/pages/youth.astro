---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import soccerBallImg from '../assets/images/soccer-ball-grass.jpg';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": ["NonprofitOrganization", "Organization"],
    "name": "GAMEC",
    "url": "https://igamec.org",
    "logo": "https://igamec.org/images/logo-bg.png",
    "description": "Global Association of Muslim Eritrean Communities — fostering unity, culture, and understanding within the Muslim Eritrean community.",
    "telephone": "+1-202-440-9089",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3420 13th St SE",
      "addressLocality": "Washington",
      "addressRegion": "DC",
      "postalCode": "20032",
      "addressCountry": "US"
    },
    "sameAs": ["https://www.facebook.com/TheOfficialGAMEC/"],
    "department": {
      "@type": "Organization",
      "name": "GAMEC Youth",
      "description": "Nurturing spiritually grounded, culturally proud, and socially responsible young people through education, sports, and cultural activities."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Programs",
        "item": "https://igamec.org/programs.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "GAMEC Youth",
        "item": "https://igamec.org/youth.html"
      }
    ]
  }
];
---
<BaseLayout
  title="Youth | GAMEC"
  description="Explore the GAMEC Youth program, dedicated to nurturing and empowering Muslim youth through education, mentorship, and community engagement."
  canonicalPath="/youth.html"
  bodyClass="no-sidebar"
  dataPage="youth"
  structuredData={structuredData}
>
  <div class="container">
    <article class="membership-page youth-page">
      <h1>GAMEC Youth</h1>

      <!-- Section: Hero -->
      <section class="youth-hero" data-section="hero" aria-label="Empowering the Next Generation">
        <h2>Empowering the Next Generation</h2>
        <p>
          The GAMEC Youth Committee is here to help you level up. We focus
          on building real connections, sharpening your skills, and
          creating safe spaces where you can lead, succeed, and own your
          future.
        </p>
        <p>
          From academic support to community vibes, we provide the tools —
          guides, training, and events — to help you thrive.
        </p>
        <Image
          src={soccerBallImg}
          alt="Soccer ball on a grass field representing GAMEC Youth sports programs"
          class="youth-hero-img"
          width={1200}
          height={600}
          format="webp"
          quality={75}
          loading="eager"
          fetchpriority="high"
        />
      </section>
      <!-- /Section: Hero -->

      <!-- Section: Our Programs -->
      <h2 data-section="our-programs">Our Programs</h2>

      <section class="youth-section" aria-label="Sports and Adventure">
        <h3><i class="fas fa-running"></i> Sports &amp; Adventure</h3>
        <ul class="youth-list">
          <li>
            <strong>Team Sports:</strong> Soccer, basketball, volleyball,
            or baseball to build discipline and teamwork.
          </li>
          <li>
            <strong>Individual Sports:</strong> Swimming, tennis, martial
            arts, or gymnastics.
          </li>
          <li>
            <strong>Outdoor Adventures:</strong> Hiking, biking, and
            camping.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Arts and Creative Expression">
        <h3>
          <i class="fas fa-palette"></i> Arts &amp; Creative Expression
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Theater &amp; Drama:</strong> Build confidence and
            find your voice on stage.
          </li>
          <li>
            <strong>Visual Arts:</strong> Drawing, photography, or
            sculpture workshops.
          </li>
          <li>
            <strong>Dance:</strong> Traditional dance connecting with
            heritage.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="STEM and Academic Excellence">
        <h3>
          <i class="fas fa-laptop-code"></i> STEM &amp; Academic
          Excellence
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Coding &amp; Robotics:</strong> Hands-on tech
            programs.
          </li>
          <li>
            <strong>Quran Recitation:</strong> Live Zoom competitions.
          </li>
          <li>
            <strong>Math &amp; Science:</strong> Annual challenges and
            real-world problems.
          </li>
          <li>
            <strong>Poetry &amp; Writing:</strong> Original poems and
            translations at GAMEC events.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Leadership and Personal Growth">
        <h3>
          <i class="fas fa-microphone-alt"></i> Leadership &amp; Personal
          Growth
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Mentorship:</strong> Career and life advice, virtual
            or in-person.
          </li>
          <li>
            <strong>Youth Councils:</strong> Make real decisions for the
            community.
          </li>
          <li>
            <strong>Debate Club:</strong> Persuasion and public speaking.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Service and Social Impact">
        <h3>
          <i class="fas fa-hands-helping"></i> Service &amp; Social Impact
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Charity &amp; Relief:</strong> Lead fundraising
            efforts globally.
          </li>
          <li>
            <strong>Social Justice:</strong> Advocate for marginalized
            communities through expert-led training.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Culture and Connection">
        <h3>
          <i class="fas fa-globe-africa"></i> Culture &amp; Connection
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Cultural Exchange:</strong> Connect with Muslim
            Eritrean youth worldwide.
          </li>
          <li>
            <strong>Social Meetups:</strong> Safe spaces and
            <a href="./matrimonial.html">Matrimonial Services</a>.
          </li>
          <li>
            <strong>Public Speaking:</strong> Grab attention and close
            with impact.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Career and Future Skills">
        <h3>
          <i class="fas fa-briefcase"></i> Career &amp; Future Skills
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Entrepreneurship:</strong> Launch your own business or
            manage big projects.
          </li>
          <li>
            <strong>Internships:</strong> Hands-on experience with GAMEC
            professionals.
          </li>
          <li>
            <strong>Financial Literacy:</strong> Budgeting, saving, and
            investing.
          </li>
        </ul>
      </section>

      <section class="youth-section" aria-label="Tutoring and Life Skills">
        <h3>
          <i class="fas fa-seedling"></i> Tutoring &amp; Life Skills
        </h3>
        <ul class="youth-list">
          <li>
            <strong>Flexible Tutoring:</strong> Give back 5–10 hours a
            week on your schedule.
          </li>
          <li>
            <strong>Life Skill Workshops:</strong> Transferable skills for
            daily life and career.
          </li>
          <li>
            <strong>Sustainability:</strong> Lead eco-friendly projects.
          </li>
        </ul>
      </section>

      <blockquote class="youth-quote">
        <em>"So let whoever aspires to this strive"</em> — Surah
        al-Mutaffifin, Verse 26
      </blockquote>
      <!-- /Section: Our Programs -->

      <!-- Section: Call To Action -->
      <section class="membership-cta" data-section="call-to-action" aria-label="Get Involved">
        <h2>Ready to Get Involved?</h2>
        <p>Pick a program and sign up today.</p>
        <div class="cta-container">
          <a
            href="./membership.html"
            class="button large primary icon solid fa-user-plus"
          >
            Register Now
          </a>
          <a
            href="./contact.html"
            class="button large accent icon solid fa-envelope"
          >
            Contact Us
          </a>
        </div>
      </section>
      <!-- /Section: Call To Action -->
    </article>
  </div>
</BaseLayout>
