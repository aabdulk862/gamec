---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import leadershipHeroImg from '../assets/images/leadership-hero.jpg';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "About Us",
        "item": "https://igamec.org/vision.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Leadership Team",
        "item": "https://igamec.org/leadership.html"
      }
    ]
  }
];
---
<BaseLayout
  title="Leadership Team | GAMEC"
  description="Learn about the dedicated individuals who lead GAMEC and guide its efforts in empowering and uniting the Muslim Eritrean community."
  canonicalPath="/leadership.html"
  bodyClass="no-sidebar"
  dataPage="leadership"
  structuredData={structuredData}
>
  <div class="container">
    <div id="content">
      <!-- Content -->
      <article>
        <h1>Leadership Team</h1>
        <!-- Section: Hero -->
        <Image
          src={leadershipHeroImg}
          alt="Modern conference room with warm lighting"
          class="page-hero-img"
          width={1920}
          height={1282}
          format="webp"
          quality={75}
          loading="eager"
          fetchpriority="high"
          data-section="hero"
        />
        <!-- /Section: Hero -->
        <!-- Section: Philosophy -->
        <p data-section="philosophy">
          Discover the faces behind the Global Association of Muslim
          Eritrean Communities (GAMEC). Our dedicated leadership team is
          committed to fostering a vibrant and united community, driven by
          shared values of inclusivity, cultural pride, and positive
          change. Their expertise guides our mission to empower, educate,
          and strengthen connections within the Muslim Eritrean community.
        </p>
        <!-- /Section: Philosophy -->

        <!-- Section: Board Members -->
        <section class="leadership-section" data-section="board-members" aria-label="Board of Directors">
          <h2>Board of Directors</h2>
          <div class="leadership-grid">
            <div class="leader-card">
              <div class="leader-avatar"><i class="fas fa-user"></i></div>
              <h3>Chairperson</h3>
              <p class="leader-role">Board Chair</p>
              <p>
                Provides strategic direction and oversees GAMEC's mission
                and governance.
              </p>
            </div>
            <div class="leader-card">
              <div class="leader-avatar"><i class="fas fa-user"></i></div>
              <h3>Vice Chairperson</h3>
              <p class="leader-role">Vice Chair</p>
              <p>
                Supports the Chair and leads key initiatives across
                community programs.
              </p>
            </div>
            <div class="leader-card">
              <div class="leader-avatar"><i class="fas fa-user"></i></div>
              <h3>Secretary</h3>
              <p class="leader-role">Board Secretary</p>
              <p>
                Manages organizational records, communications, and
                meeting coordination.
              </p>
            </div>
            <div class="leader-card">
              <div class="leader-avatar"><i class="fas fa-user"></i></div>
              <h3>Treasurer</h3>
              <p class="leader-role">Board Treasurer</p>
              <p>
                Oversees financial management, budgeting, and fiscal
                accountability.
              </p>
            </div>
          </div>
        </section>
        <!-- /Section: Board Members -->

        <!-- Section: Call To Action -->
        <section class="leadership-cta" data-section="call-to-action" aria-label="Get involved with leadership">
          <p>
            Our board members volunteer their time and expertise to serve
            the Muslim Eritrean community. Interested in getting involved?
            We welcome dedicated individuals who share our vision.
          </p>
          <a href="./contact.html" class="button icon solid fa-envelope"
            >Get in Touch</a
          >
          <a
            href="./history.html"
            class="button alt icon solid fa-landmark"
            >Our History</a
          >
        </section>
        <!-- /Section: Call To Action -->
      </article>
    </div>
  </div>
</BaseLayout>
