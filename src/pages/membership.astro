---
import BaseLayout from '@layouts/BaseLayout.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Membership",
        "item": "https://igamec.org/membership.html"
      }
    ]
  }
];
---
<BaseLayout
  title="Membership | GAMEC"
  description="Join GAMEC and become a part of a vibrant community of Muslim Eritreans. Experience the benefits of membership and contribute to positive change."
  canonicalPath="/membership.html"
  bodyClass="no-sidebar"
  dataPage="membership"
  structuredData={structuredData}
>
  <div class="container">
    <article class="membership-page">
      <h1>Membership</h1>

      <p>
        Join the Global Association of Muslim Eritrean Communities (GAMEC)
        and step into something truly special — a diverse, vibrant, and
        deeply connected family of Muslim Eritreans from around the world.
        We're not just an organization; we're a movement rooted in faith,
        culture, and shared purpose. Your membership isn't just a sign-up
        — it's a powerful act of unity. It fuels our collective mission to
        uplift one another, preserve our heritage, empower our youth,
        support our families, and show the beauty of Islam to the wider
        society.
      </p>
      <br />

      <!-- Section: Benefits -->
      <section class="membership-benefits" data-section="benefits" aria-label="Membership benefits">
        <h2>Together We Rise — Join GAMEC</h2>

        <div class="benefits-grid">
          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="fas fa-hand-holding-heart"></i>
            </div>
            <h3>Support Our Vision & Programs</h3>
            <p>
              Help advance GAMEC's core goals and planned initiatives
              worldwide.
            </p>
          </div>

          <div class="benefit-item">
            <div class="benefit-icon"><i class="fas fa-globe"></i></div>
            <h3>Promote a Positive Image of Islam</h3>
            <p>
              Share authentic Islamic teachings and values with broader
              society.
            </p>
          </div>

          <div class="benefit-item">
            <div class="benefit-icon"><i class="fas fa-users"></i></div>
            <h3>Empower Youth & Future Leaders</h3>
            <p>
              Support programs that develop confident, capable
              next-generation leaders.
            </p>
          </div>
        </div>
      </section>
      <!-- /Section: Benefits -->

      <!-- Section: FAQ -->
      <section id="faq" class="membership-faq" data-section="faq" aria-label="Frequently Asked Questions">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Who can join GAMEC?</summary>
            <p>
              Any Muslim Eritrean — or anyone who supports our mission —
              is welcome to join, regardless of where you live. We have
              members across North America, Europe, the Middle East, and
              Africa.
            </p>
          </details>
          <details class="faq-item">
            <summary>What programs is GAMEC planning?</summary>
            <p>
              We're building programs for every generation: GAMEC Youth,
              GAMEC Sisters, GAMEC Seniors, GAMEC Professionals, health
              services, relief and charity work, and matrimonial services.
              These are in development — visit our
              <a href="./programs.html">programs page</a> to learn more
              about what's coming.
            </p>
          </details>
          <details class="faq-item">
            <summary>
              How can I volunteer or contribute beyond membership?
            </summary>
            <p>
              We're always looking for volunteers — whether it's helping
              at events, mentoring youth, or lending professional skills.
              Reach out through our
              <a href="./contact.html">contact page</a> and we'll connect
              you with the right program.
            </p>
          </details>
          <details class="faq-item">
            <summary>
              How do I stay updated on GAMEC news and events?
            </summary>
            <p>
              Follow us on
              <a
                href="https://www.facebook.com/TheOfficialGAMEC/"
                target="_blank"
                rel="noopener noreferrer"
                >Facebook</a
              >, join our WhatsApp community groups, or simply sign up as
              a member to receive updates directly.
            </p>
          </details>
        </div>
      </section>
      <!-- /Section: FAQ -->

      <!-- Section: Call To Action -->
      <section class="membership-cta" data-section="call-to-action" aria-label="Join GAMEC">
        <div class="cta-container">
          <a
            href="https://forms.fillout.com/t/bsiBP5jqLBus"
            target="_blank"
            rel="noopener noreferrer"
            class="button large primary icon solid fa-user-plus"
          >
            Join Now
          </a>

          <a
            href="./donate.html"
            class="button large accent icon solid fa-hand-holding-usd"
          >
            Support Us
          </a>
        </div>
      </section>
      <!-- /Section: Call To Action -->

      <!-- Section: Closing Note -->
      <section class="membership-note" data-section="closing-note" aria-label="Closing note">
        <p>
          Your participation strengthens our community and brings us
          closer to our goals. May Allah bless and reward every effort
          made in His cause.
        </p>
      </section>
      <!-- /Section: Closing Note -->
    </article>
  </div>
</BaseLayout>
