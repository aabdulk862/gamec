---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import cityImg from '../assets/images/city.jpg';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": ["NonprofitOrganization", "Organization"],
    "name": "GAMEC",
    "url": "https://igamec.org",
    "logo": "https://igamec.org/images/logo-bg.png",
    "description": "Global Association of Muslim Eritrean Communities — fostering unity, culture, and understanding within the Muslim Eritrean community.",
    "telephone": "+1-202-440-9089",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3420 13th St SE",
      "addressLocality": "Washington",
      "addressRegion": "DC",
      "postalCode": "20032",
      "addressCountry": "US"
    },
    "sameAs": ["https://www.facebook.com/TheOfficialGAMEC/"],
    "department": {
      "@type": "Organization",
      "name": "GAMEC Professionals",
      "description": "Connecting Muslim Eritrean professionals across industries with networking, mentorship, and career development opportunities."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Programs",
        "item": "https://igamec.org/programs.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Muslim Professionals Home",
        "item": "https://igamec.org/professionals.html"
      }
    ]
  }
];
---
<BaseLayout
  title="Muslim Professionals Home | GAMEC"
  description="GAMEC's Muslim Professionals Home — the dedicated online space for Muslim Eritrean professionals worldwide to connect, collaborate, and contribute with purpose."
  canonicalPath="/professionals.html"
  bodyClass="no-sidebar"
  dataPage="professionals"
  structuredData={structuredData}
>
  <div class="container">
    <article class="membership-page professionals-page">
      <h1>GAMEC Professionals</h1>

      <!-- Section: Hero -->
      <section class="professionals-hero" data-section="hero" aria-label="Welcome Home, Fellow Professionals">
        <h2>Welcome Home, Fellow Professionals</h2>
        <p class="professionals-salam">
          <em>Assalamu alaikum wa rahmatullahi wa barakatuh.</em>
        </p>
        <Image
          src={cityImg}
          alt="City skyline representing GAMEC's global professional network"
          class="professionals-hero-img"
          width={6000}
          height={4000}
          format="webp"
          quality={75}
          loading="eager"
          fetchpriority="high"
        />
        <p class="professionals-tagline">You are not alone.</p>
        <p>
          GAMEC's Muslim Professionals Home is the dedicated online space
          created exclusively for Muslim Eritrean professionals worldwide
          — doctors, engineers, educators, entrepreneurs, lawyers, IT
          specialists, researchers, and leaders in every field.
        </p>
      </section>
      <!-- /Section: Hero -->

      <!-- Section: What You Can Do -->
      <section
        class="professionals-section"
        data-section="what-you-can-do"
        aria-label="What You Can Do"
      >
        <h2>What You Can Do Inside the Muslim Professionals Home</h2>
        <ul class="professionals-list">
          <li>
            <strong>Exchange real-world experiences</strong> with
            like-minded brothers and sisters who understand your journey
            as both a professional and a Muslim Eritrean.
          </li>
          <li>
            <strong>Form research teams</strong> based on your unique
            skills to solve real challenges facing our communities — from
            healthcare and education to economic development and
            technology.
          </li>
          <li>
            <strong>Launch service projects</strong> that directly benefit
            Muslim communities in Eritrea, the Horn of Africa, the
            diaspora, and around the world.
          </li>
          <li>
            <strong>Mentor and be mentored</strong>, grow your career, and
            open doors you never knew existed — all while earning the
            pleasure of Allah (SWT) through service to the Ummah.
          </li>
        </ul>
      </section>
      <!-- /Section: What You Can Do -->

      <!-- Section: Why Join -->
      <section class="professionals-section" data-section="why-join" aria-label="Why Muslim Eritrean Professionals Are Joining">
        <h2>Why Muslim Eritrean Professionals Are Joining</h2>
        <ul class="professionals-list">
          <li>
            <strong>Faith-driven impact:</strong> Use the knowledge and
            skills Allah has blessed you with to strengthen our global
            Muslim Eritrean community and serve the wider Ummah.
          </li>
          <li>
            <strong>Global network:</strong> Connect instantly with
            professionals across continents — no borders, no barriers.
          </li>
          <li>
            <strong>Real collaboration:</strong> Turn ideas into research
            papers, community programs, startups, and initiatives that
            create lasting change.
          </li>
          <li>
            <strong>Professional growth:</strong> Access mentorship, job
            opportunities, partnerships, and resources tailored for Muslim
            professionals.
          </li>
          <li>
            <strong>Barakah in your work:</strong> Every hour you invest
            here becomes sadaqah jariyah when it helps a fellow Muslim.
          </li>
        </ul>
      </section>
      <!-- /Section: Why Join -->

      <!-- Section: Closing Message -->
      <section
        class="professionals-closing"
        data-section="closing-message"
        aria-label="Closing message"
      >
        <p>
          This is more than a network — it is your professional home. A
          place where your expertise meets your iman. Where your career
          advances and your community is uplifted at the same time.
        </p>
        <p class="professionals-ready">
          Ready to make a difference with your skills?
        </p>
        <h2>Join the Muslim Professionals Home Today</h2>
      </section>
      <!-- /Section: Closing Message -->

      <!-- Section: WhatsApp Group -->
      <section
        class="professionals-whatsapp"
        data-section="whatsapp-group"
        aria-label="WhatsApp Group"
      >
        <i class="fab fa-whatsapp"></i>
        <p>
          <strong>WhatsApp Group — launching soon.</strong>
          <a href="./contact.html">Contact us</a> to express interest in
          our dedicated WhatsApp group where professionals can connect and
          collaborate in real time.
        </p>
      </section>
      <!-- /Section: WhatsApp Group -->

      <!-- Section: Call To Action -->
      <section class="membership-cta" data-section="call-to-action" aria-label="Join GAMEC Professionals">
        <div class="cta-container">
          <a
            href="./membership.html"
            target="_blank"
            rel="noopener noreferrer"
            class="button large primary icon solid fa-user-plus"
          >
            Join Now
          </a>
          <a
            href="./contact.html"
            class="button large accent icon solid fa-envelope"
          >
            Contact Us
          </a>
        </div>
      </section>
      <!-- /Section: Call To Action -->
    </article>
  </div>
</BaseLayout>
