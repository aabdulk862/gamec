---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationMethods from '@components/DonationMethods.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Donate",
        "item": "https://igamec.org/donate.html"
      }
    ]
  }
];
---
<BaseLayout
  title="Donate | GAMEC"
  description="Support the Global Association of Muslim Eritrean Communities (GAMEC) by donating to our initiatives. Your contributions help uplift and empower communities worldwide."
  canonicalPath="/donate.html"
  bodyClass="no-sidebar"
  dataPage="donate"
  structuredData={structuredData}
>
  <div class="container">
    <div id="content">
      <!-- Content -->
      <article>
        <h1>Donate</h1>

        <p>
          Your support fuels our mission and makes a tangible difference
          in the lives of Muslim Eritreans inside Eritrea and communities
          worldwide. By donating to the Global Association of Muslim
          Eritrean Communities (GAMEC), you contribute to initiatives that
          uplift, empower, and unite our community. Every contribution, no
          matter the size, is a step towards positive change and greater
          opportunities for individuals and families within our community.
        </p>

        <div class="trust-badge" style="margin-bottom: 2em">
          <i class="fas fa-shield-alt"></i>
          GAMEC Inc. is a registered 501(c)(3) non-profit organization.
          All donations are tax-deductible.
        </div>

        <DonationMethods />
      </article>
    </div>
  </div>
</BaseLayout>
