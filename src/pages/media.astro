---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import LivestreamCard from '@components/LivestreamCard.astro';
import MediaGallery from '@components/MediaGallery.astro';
import ImageModal from '@components/ImageModal.astro';

import logoBgImg from '../assets/images/logo-bg.png';
import asmaraMosqueImg from '../assets/images/asmara-mosque.jpg';
import asSahabaImg from '../assets/images/as-sahaba.jpg';
import eventRoomImg from '../assets/images/event-room.jpg';
import jebenaImg from '../assets/images/jebena.png';
import awateLibrary1Img from '../assets/images/awate-library1.jpg';
import awateLibrary2Img from '../assets/images/awate-library2.jpg';
import awateLibrary3Img from '../assets/images/awate-library3.jpg';
import awateLibrary4Img from '../assets/images/awate-library4.png';
import kaaba2Img from '../assets/images/kaaba2.jpg';
import madinahImg from '../assets/images/madinah.jpeg';

const communityImages = [
  {
    src: logoBgImg,
    alt: "GAMEC - Global Association of Muslim Eritrean Communities official logo",
    caption: "GAMEC Logo",
    width: 1072,
    height: 715,
  },
  {
    src: asmaraMosqueImg,
    alt: "Khulafa al-Rashidun Mosque in Asmara, Eritrea",
    caption: "Khulafa al-Rashidun Mosque, Asmara",
    width: 1800,
    height: 1200,
  },
  {
    src: asSahabaImg,
    alt: "The Sahaba Mosque in Massawa, Eritrea - 7th Century historic mosque",
    caption: "As-Sahaba Mosque, Massawa (7th Century)",
    width: 600,
    height: 400,
  },
  {
    src: eventRoomImg,
    alt: "GAMEC community event and gathering room",
    caption: "Community Event Space",
    width: 6016,
    height: 4016,
  },
  {
    src: jebenaImg,
    alt: "Traditional Eritrean jebena coffee pot",
    caption: "Traditional Eritrean Jebena Coffee",
    width: 600,
    height: 400,
  },
];

const awateLibraryImages = [
  {
    src: awateLibrary1Img,
    alt: "Sisters Vocational and Computer Class at Awate Library in Cairo, Egypt - Photo 1",
    caption: "Vocational Training Session",
    width: 600,
    height: 400,
  },
  {
    src: awateLibrary2Img,
    alt: "Sisters Vocational and Computer Class at Awate Library in Cairo, Egypt - Photo 2",
    caption: "Computer Skills Workshop",
    width: 600,
    height: 400,
  },
  {
    src: awateLibrary3Img,
    alt: "Sisters Vocational and Computer Class at Awate Library in Cairo, Egypt - Photo 3",
    caption: "Group Learning Activity",
    width: 600,
    height: 400,
  },
  {
    src: awateLibrary4Img,
    alt: "Sisters Vocational and Computer Class at Awate Library in Cairo, Egypt - Photo 4",
    caption: "Class Graduation",
    width: 600,
    height: 400,
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://igamec.org/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Media",
        "item": "https://igamec.org/media.html"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "GAMEC Media Gallery",
    "description": "Photos, videos, and media from GAMEC community events and activities.",
    "url": "https://igamec.org/media.html",
    "publisher": {
      "@type": "Organization",
      "name": "GAMEC"
    }
  }
];
---
<BaseLayout
  title="Media | GAMEC"
  description="Journey through a visual showcase of vibrant moments and cherished memories from GAMEC's events and community activities."
  canonicalPath="/media.html"
  bodyClass="no-sidebar"
  dataPage="media"
  structuredData={structuredData}
  pageScripts={["/scripts/media-gallery.js"]}
>
  <div class="container">
    <article id="content">
      <h1>GAMEC Media</h1>
      <p>
        Welcome to the Media section of the Global Association of Muslim
        Eritrean Communities (GAMEC). Explore photos, videos, audio, and
        stories that capture our vibrant events, cultural heritage, and
        community spirit.
      </p>
      <div class="bottom-border"></div>

      <!-- Section: Livestream -->
      <section class="livestream-section" data-section="livestream" aria-label="Live from the Holy Cities">
        <h2>Live from the Holy Cities</h2>
        <p>
          Experience the spiritual heart of Islam with live broadcasts
          from the two holiest cities.
        </p>
        <div class="livestream-grid">
          <LivestreamCard
            title="Makkah"
            thumbnailSrc={kaaba2Img}
            thumbnailAlt="Live stream from Makkah - The Holy Kaaba"
            thumbnailWidth={3277}
            thumbnailHeight={4096}
            embedUrl="https://www.youtube.com/channel/UCqDUJp6Z4wyFkDJGqd0EP4Q"
            description="Watch the live broadcast from the Holy Kaaba in Makkah, the most sacred site in Islam."
            detailed={true}
          />
          <LivestreamCard
            title="Madinah"
            thumbnailSrc={madinahImg}
            thumbnailAlt="Live stream from Madinah - The Prophet's Mosque"
            thumbnailWidth={1244}
            thumbnailHeight={700}
            embedUrl="https://www.youtube.com/@ArRahmanIslamic"
            description="Watch the live broadcast from the Prophet's Mosque in Madinah, the second holiest site in Islam."
            detailed={true}
          />
        </div>
      </section>
      <div class="bottom-border"></div>

      <!-- Section: Photo Gallery -->
      <section class="media-category" data-section="photo-gallery" aria-label="Photo Gallery">
        <h2>Photo Gallery</h2>
        <p>
          A collection of portraits, artwork, historical sites, and
          moments from community events and activities. Click any image to view full size.
        </p>

        <MediaGallery images={communityImages} columns={3} />

        <MediaGallery
          images={awateLibraryImages}
          title="Awate Library – Sisters' Vocational & Computer Class (Cairo, Egypt)"
          columns={4}
        />
      </section>
      <div class="bottom-border"></div>

      <!-- Section: Videos -->
      <section class="media-category" data-section="videos" aria-label="Video Production">
        <h2>Video Production</h2>
        <p>
          Lectures, Dawah content, event highlights, community stories,
          and more. GAMEC is producing original content including
          community interviews and educational series.
        </p>
        <p class="coming-soon">
          Content is currently in production — check back for updates.
        </p>
      </section>
      <div class="bottom-border"></div>

      <!-- Section: Audio -->
      <section class="media-category" data-section="audio" aria-label="Audio">
        <h2>Audio</h2>
        <p>
          Sermons, Islamic teachings, reflections, and community
          discussions.
        </p>
        <p class="coming-soon">Audio collection is in development.</p>
      </section>
      <div class="bottom-border"></div>

      <!-- Section: Articles -->
      <section class="media-category" data-section="articles" aria-label="Articles">
        <h2>Articles</h2>
        <p>
          In-depth reads on Islamic teachings, Eritrean heritage,
          community issues, and more – written by members and guests.
        </p>
        <p class="coming-soon">Articles section launching soon.</p>
      </section>
      <div class="bottom-border"></div>

      <!-- Section: Social Media -->
      <section class="media-category" data-section="social-media" aria-label="Social Media">
        <h2>Social Media</h2>
        <p>
          Follow us for real-time updates, photos, stories, and community
          connection:
        </p>
        <div class="social-links">
          <a
            href="https://www.facebook.com/TheOfficialGAMEC/"
            class="button icon brands fa-facebook"
            target="_blank"
            rel="noopener noreferrer"
          >Facebook
            <span class="visually-hidden">(opens in new tab)</span>
          </a>
          <a
            href="#"
            class="button icon brands fa-instagram"
            target="_blank"
            rel="noopener noreferrer"
          >Instagram (Coming Soon)
            <span class="visually-hidden">(opens in new tab)</span>
          </a>
          <a
            href="#"
            class="button icon brands fa-whatsapp"
            target="_blank"
            rel="noopener noreferrer"
          >WhatsApp Group (Coming Soon)
            <span class="visually-hidden">(opens in new tab)</span>
          </a>
        </div>
      </section>
    </article>
  </div>

  <!-- Lightbox modal (rendered once, controlled by JS) -->
  <ImageModal />
</BaseLayout>
