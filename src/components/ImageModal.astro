---
/**
 * ImageModal.astro — Lightbox modal shell rendered at build time.
 * The interactivity (open/close/nav/keyboard) is handled by media-gallery.js.
 * This component should be included once per page that uses MediaGallery.
 */
---

<div
  class="image-modal"
  id="image-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  aria-hidden="true"
>
  <div class="image-modal__overlay" data-modal-close></div>
  <div class="image-modal__content">
    <button
      class="image-modal__close"
      type="button"
      aria-label="Close image viewer"
      data-modal-close
    >
      <i class="fas fa-times"></i>
    </button>
    <button
      class="image-modal__nav image-modal__nav--prev"
      type="button"
      aria-label="Previous image"
      data-modal-prev
    >
      <i class="fas fa-chevron-left"></i>
    </button>
    <figure class="image-modal__figure">
      <img
        class="image-modal__img"
        src=""
        alt=""
        loading="eager"
      />
      <figcaption class="image-modal__caption"></figcaption>
    </figure>
    <button
      class="image-modal__nav image-modal__nav--next"
      type="button"
      aria-label="Next image"
      data-modal-next
    >
      <i class="fas fa-chevron-right"></i>
    </button>
    <div class="image-modal__counter" aria-live="polite"></div>
  </div>
</div>
