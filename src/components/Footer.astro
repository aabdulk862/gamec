---
/**
 * Footer.astro
 * Site footer with 4-column layout: Sitemap, Resources, Quick Links, Contact.
 * Renders social media links, copyright notice, and site credit at build time.
 */
---

<footer id="footer" role="contentinfo" class="container">
  <div class="row">
    <!-- Section: Sitemap -->
    <div class="col-3 col-6-medium col-12-small" data-section="sitemap">
      <section class="widget links" aria-label="Sitemap">
        <h2 class="widget__title">Sitemap</h2>
        <ul class="style2 sitemap">
          <li><a href="./index.html">Home</a></li>
          <li><a href="./vision.html">Mission and Vision</a></li>
          <li><a href="./history.html">History</a></li>
          <li><a href="./membership.html">Membership</a></li>
          <li><a href="./programs.html">Programs</a></li>
          <li><a href="./matrimonial.html">Matrimonial Services</a></li>
          <li><a href="./media.html">Media</a></li>
          <li><a href="./resources.html">Resources</a></li>
        </ul>
      </section>
    </div>
    <!-- /Section: Sitemap -->
    <!-- Section: Resources -->
    <div class="col-3 col-6-medium col-12-small" data-section="resources">
      <section class="widget links" aria-label="Resources">
        <h2 class="widget__title">Resources</h2>
        <ul class="style2">
          <li><a href="./resources.html">Education</a></li>
          <li><a href="./resources.html">Relevant Websites</a></li>
          <li><a href="./resources.html">Event Calendar</a></li>
          <li><a href="./donate.html">Donate</a></li>
        </ul>
      </section>
    </div>
    <!-- /Section: Resources -->
    <!-- Section: Quick Links -->
    <div class="col-3 col-6-medium col-12-small" data-section="quick-links">
      <section class="widget links" aria-label="Quick Links">
        <h2 class="widget__title">Quick Links</h2>
        <ul class="style2">
          <li><a href="./membership.html#faq">FAQ</a></li>
          <li><a href="./donate.html">Donate</a></li>
          <li><a href="./contact.html">Contact Us</a></li>
          <li><a href="./membership.html">Become a Member</a></li>
        </ul>
      </section>
    </div>
    <!-- /Section: Quick Links -->
    <!-- Section: Contact -->
    <div class="col-3 col-6-medium col-12-small" data-section="contact">
      <section class="widget contact last" aria-label="Contact Us">
        <h2 class="widget__title">Contact Us</h2>
        <p>
          3420 13th ST SE<br />
          Washington, DC 20032<br />
          +1 (202) 440-9089<br />
          <a
            href="https://www.facebook.com/TheOfficialGAMEC/"
            target="_blank"
            rel="noopener noreferrer"
          >facebook.com/TheOfficialGAMEC</a>
        </p>
      </section>
    </div>
    <!-- /Section: Contact -->
  </div>
</footer>
<!-- Section: Copyright -->
<div id="copyright" data-section="copyright">
  <p>&copy; GAMEC Inc. All rights reserved.</p>
  <p class="site-credit">
    Built by
    <a
      href="https://adversesolutions.com/"
      target="_blank"
      rel="noopener noreferrer"
    >Adverse LLC</a>
  </p>
</div>
<!-- /Section: Copyright -->
