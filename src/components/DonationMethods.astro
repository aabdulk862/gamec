---
// Self-contained component for Square/PayPal/Zelle donation methods
---

<!-- Section: Square Donation -->
<section
  class="donation-section"
  id="square-donation"
  data-section="square-donation"
  aria-label="Donate via Square"
>
  <h2>Donate via Square</h2>
  <p>
    Securely donate using your credit or debit card through Square.
  </p>
  <a
    href="https://igamec.square.site/"
    class="button icon solid fa-arrow-circle-right"
    target="_blank"
    rel="noopener noreferrer"
  >Donate with Square</a>
</section>
<!-- /Section: Square Donation -->

<!-- Section: PayPal Donation -->
<section
  class="donation-section"
  id="paypal-donation"
  data-section="paypal-donation"
  aria-label="Donate via PayPal"
>
  <h2>Donate via PayPal</h2>
  <p>Use your PayPal account to make a donation.</p>
  <a
    href="https://www.paypal.com/ncp/payment/GJ95SWHHMXJZC"
    class="button icon solid fa-arrow-circle-right"
    target="_blank"
    rel="noopener noreferrer"
  >Donate with PayPal</a>
</section>
<!-- /Section: PayPal Donation -->

<!-- Section: Zelle Donation -->
<section
  id="zelle-donation"
  class="donation-section"
  data-section="zelle-donation"
  aria-label="Donate via Zelle"
>
  <h2>Donate via Zelle</h2>
  <ol>
    <li>
      <strong>Log In:</strong> Access your bank's online or mobile
      app with Zelle.
    </li>
    <li>
      <strong>Send Money:</strong> Choose the "Send Money" option
      using Zelle.
    </li>
    <li>
      <strong>Recipient Number:</strong> Enter:
      <a style="font-weight: 500" href="tel:+12024409089">
        +1 (202) 440-9089</a>
      <i>(GAMEC Inc)</i>.
    </li>
    <li>
      <strong>Enter Amount:</strong> Specify your donation amount.
    </li>
    <li>
      <strong>Add Note:</strong> Include any specific instructions
      or designations.
    </li>
    <li>
      <strong>Confirm:</strong> Review and send your donation.
    </li>
  </ol>
</section>
<!-- /Section: Zelle Donation -->
